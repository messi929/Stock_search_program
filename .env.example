# 실행 모드: server(크롤링+API) / client(원격 접속)
RUN_MODE=server

# 서버 포트 (Cloud Run은 자동 할당)
PORT=8501

# 클라이언트 모드: 접속할 서버 URL
SERVER_URL=http://localhost:8501

# 데이터 수집 모드:
#   full     — 크롤링 + Firestore 쓰기 (로컬 서버, collector.py 없이 단독 운영)
#   readonly — Firestore 읽기만 (Cloud Run 서빙 전용, collector.py가 별도 크롤링)
COLLECT_MODE=full

# 관리자 API 키 (수동 갱신 등)
ADMIN_KEY=

# Firebase 서비스 계정 키 경로 (로컬 개발용, 미설정 시 프로젝트 루트 자동 탐색)
FIREBASE_KEY_PATH=

# Firebase 서비스 계정 JSON 문자열 (Cloud Run 등 컨테이너 배포용)
# Cloud Run에서는 Secret Manager에 저장 후 환경변수로 마운트
FIREBASE_CREDENTIALS=

# Firebase Auth (로그인 시스템, AUTH_ENABLED=true 시 활성화)
AUTH_ENABLED=false
FIREBASE_WEB_API_KEY=
FIREBASE_PROJECT_ID=

# Cloud Run URL (collector 수집 후 리로드 알림용)
CLOUD_RUN_URL=https://stock-screener-119320994983.asia-northeast3.run.app

# 텔레그램 알림 (collector.py 수집 실패/검증 결과 알림)
# 1) @BotFather에서 봇 생성 → 토큰 발급
# 2) @userinfobot에게 메시지 → chat_id 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
